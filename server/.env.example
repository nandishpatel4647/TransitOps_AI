# Server port (Railway sets this automatically in production)
PORT=3000

# Secret key for signing JWT tokens — use a strong random string in production
JWT_SECRET=some_jwt_secret_here

# Prisma database connection string
# SQLite (default):  file:./dev.db
# PostgreSQL:        postgresql://user:password@host:5432/dbname
DATABASE_URL="file:./dev.db"

# Environment mode: "development" or "production"
# In production, the server serves the built React frontend as static files
NODE_ENV=development

# (Optional) Additional allowed CORS origin for the frontend
# Not needed in production when the server serves the frontend directly
# CORS_ORIGIN=https://your-frontend-domain.com
